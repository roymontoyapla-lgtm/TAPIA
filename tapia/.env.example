# ============================================================
# TAPIA - Variables de entorno
# Copia este fichero como ".env" y rellena tus valores reales.
# NUNCA subas el fichero .env a un repositorio git.
# ============================================================

# --- OpenAI ---
OPENAI_API_KEY=sk-...

# --- Anthropic (alternativa a OpenAI) ---
ANTHROPIC_API_KEY=sk-ant-...

# --- Entorno ---
# "development" | "production"
TAPIA_ENV=development
